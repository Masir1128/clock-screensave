{
  "name": "clock-screensaver",
  "version": "1.0.0",
  "description": "时钟屏幕保护程序 — A beautiful clock screensaver for macOS",
  "main": "main.js",
  "author": "科学羊 <masir1128@github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Masir1128/clock-screensave.git"
  },
  "homepage": "https://github.com/Masir1128/clock-screensave#readme",
  "scripts": {
    "start": "electron .",
    "gen-icon": "node scripts/gen-icon.js",
    "build": "npm run gen-icon && electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mayang.clock-screensaver",
    "productName": "时钟屏保",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }]
    },
    "files": ["main.js", "preload.js", "index.html", "assets/"]
  }
}
